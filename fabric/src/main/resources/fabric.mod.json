{
	"schemaVersion": 1,
	"id": "pvplockmod",
	"version": "${version}",
	"name": "ItemLock",
	"description": "Press P to lock a hotbar slot in place so you can't accidentally drop or move that item during PvP fights.",
	"authors": [
		"You"
	],
	"contact": {
		"issues": "https://github.com/luka321-boo/ItemLock/issues",
		"sources": "https://github.com/luka321-boo/ItemLock"
	},
	"license": "CC0-1.0",
	"icon": "assets/pvplockmod/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"net.pvplock.PvPLockMod"
		],
		"client": [
			"net.pvplock.client.PvPLockModClient"
		]
	},
	"mixins": [
		{
			"config": "pvplockmod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*"
	}
}
